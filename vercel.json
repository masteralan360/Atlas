{
    "rewrites": [
        {
            "source": "/api-xeiqd/(.*)",
            "destination": "/api/xeiqd?path=$1"
        },
        {
            "source": "/api-xeiqd",
            "destination": "/api/xeiqd"
        },
        {
            "source": "/api-forexfy/(.*)",
            "destination": "/api/forexfy?path=$1"
        },
        {
            "source": "/api-forexfy",
            "destination": "/api/forexfy"
        },
        {
            "source": "/((?!api-xeiqd(?:/|$)|api-forexfy(?:/|$)|assets(?:/|$)|.*\\.[^/]+$).*)",
            "has": [
                {
                    "type": "host",
                    "value": "marketplace-atlas.vercel.app"
                }
            ],
            "destination": "/marketplace.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
