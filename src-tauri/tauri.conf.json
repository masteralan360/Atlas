{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Asaas",
  "version": "0.0.54",
  "identifier": "com.asaas.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Asaas",
        "label": "main",
        "width": 1700,
        "height": 990,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "devtools": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "csp": "default-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: asset://* http://asset.localhost https://asset.localhost https: data: blob:; media-src 'self' asset: asset://* http://asset.localhost https://asset.localhost; frame-src 'self' blob:; connect-src 'self' https: ws: blob:; font-src 'self' https: data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://asaas-r2-proxy.alanepic360.workers.dev/asaas-updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwOTQ3MENENDBDQTNBRjIKUldUeU9zcEF6WENVNEkzd3FGOFlKckMzMmN6YWNEQjU4ZDFKYXl5dTRnZWsxMzJYZ1ZxenBKdDcK"
    }
  }
}